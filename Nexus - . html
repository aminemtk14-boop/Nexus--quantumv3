// ─── MAIN FETCH ────────────────────────────────────────
async function startFetch(){
  if(fetching)return;fetching=true;
  setSt('loading');
  try{
    setLoad('جاري جلب بيانات السوق...','▸ يجرب الخادم '+(PROXY_IDX+1)+' من 8...',10);
    var ps=document.getElementById('proxy-status');
    if(ps){var pNames=['مباشر','AllOrigins','cors.sh','Corsfix','CodeTabs','cors.x2u.in','killcors','thingproxy'];
    ps.textContent='الخادم الحالي: '+( pNames[PROXY_IDX]||'—');}
    // Step 1: All tickers
    const tickers = await cfetch(`${BSPOT}/ticker/24hr`);
    if(!Array.isArray(tickers))throw new Error('Invalid ticker response');
    setLoad(`تم جلب ${tickers.length} عملة — جاري التحليل...`,'▸ Computing 14-factor scores',40);

    // Process tickers
    const usdt = tickers.filter(t=>t.symbol.endsWith('USDT')&&+t.quoteVolume>80000);
    usdt.forEach(t=>{
      const sym=t.symbol;
      const pch=((+t.lastPrice-+t.openPrice)/+t.openPrice*100);
      const c={
        s:sym, c:+t.lastPrice, o:+t.openPrice,
        h:+t.highPrice, l:+t.lowPrice,
        q:+t.quoteVolume, n:+t.count,
        P:pch, _kl:KLINES.get(sym)||null,
        _fut:FUTS.get(sym)||null
      };
      // Update history
      let hv=HVOL.get(sym)||[];hv.push(c.q);if(hv.length>30)hv=hv.slice(-30);HVOL.set(sym,hv);
      let hp=HPRC.get(sym)||[];hp.push(c.c);if(hp.length>10)hp=hp.slice(-10);HPRC.set(sym,hp);
      c.score=computeScore(c);c.om=omegaScore(c);c.rank=getRank(c.score);c.sigs=getSigs(c);c.plan=calcPlan(c);
      COINS.set(sym,c);
    });

    setLoad('جاري جلب Futures...','▸ GET /fapi/v1/premiumIndex',60);
    // Step 2: Futures
    try{
      const fdata = await cfetch(`${BFAPI}/premiumIndex`);
      if(Array.isArray(fdata)){
        fdata.forEach(f=>{
          if(!f?.symbol?.endsWith('USDT'))return;
          const fr=+f.lastFundingRate;
          const futsig=fr>0.001?'BX':fr>0.0003?'B':fr<-0.001?'BX_':fr<-0.0003?'BR':'N';
          FUTS.set(f.symbol,{mp:+f.markPrice,ip:+f.indexPrice,fr,frS:futsig,next:f.nextFundingTime,prem:0});
        });
        // Enrich coins
        COINS.forEach((c,sym)=>{const f=FUTS.get(sym);if(f){f.prem=((f.mp-c.c)/c.c*100);c._fut=f;c.score=computeScore(c);c.om=omegaScore(c);}});
      }
    }catch(e){}

    setLoad('جاري جلب Taker Buy من Kline...','▸ GET /api/v3/klines (top 60)',75);
    // Step 3: Klines for top coins
    const topCoins=Array.from(COINS.values()).sort((a,b)=>+b.q-+a.q).slice(0,60).map(c=>c.s);
    await fetchKlinesBatch(topCoins, 75, 95);

    setLoad('تحديث الإشارات...','▸ Rendering results',98);
    setSt('live');
    totalLoaded=true;
    hideLoadScreen();
    doRender();
    startCountdown();
    setLoad('','',100);
  }catch(e){
    setSt('err');
    setLoad('❌ فشل الاتصال. تحقق من الإنترنت.','▸ '+e.message,0);
    showRetry();
  }finally{fetching=false;}
}

async function fetchKlinesBatch(symbols, pFrom, pTo){
  const step=(pTo-pFrom)/Math.max(symbols.length,1);
  let done=0;
  for(const sym of symbols){
    try{
      const data=await cfetch(`${BSPOT}/klines?symbol=${sym}&interval=5m&limit=12`);
      if(!Array.isArray(data)||data.length<3)continue;
      const tbrs=data.map(k=>+k[7]>0?+k[10]/+k[7]:0.5);
      const avg=tbrs.reduce((a,b)=>a+b,0)/tbrs.length;
      const rec=tbrs.slice(-3).reduce((a,b)=>a+b,0)/3;
      let vn=0,vd=0;
      data.forEach(k=>{const tp=(+k[2]+k[3]+k[4])/3;vn+=tp*+k[5];vd+=+k[5];});
      const vwap=vd>0?vn/vd:0;
      const prc=data.map(k=>+k[4]);
      const vel=prc.length>=4?((prc[prc.length-1]-prc[prc.length-4])/prc[prc.length-4]*100):0;
      KLINES.set(sym,{tbr:rec,avg,trend:rec-avg,vwap,vel,n:data.length});
      // Update coin
      const coin=COINS.get(sym);
      if(coin){coin._kl=KLINES.get(sym);coin.score=computeScore(coin);coin.om=omegaScore(coin);coin.rank=getRank(coin.score);coin.sigs=getSigs(coin);coin.plan=calcPlan(coin);}
      klinesDone++;done++;
      document.getElementById('m5').textContent=KLINES.size;
    }catch(e){}
    // Progress
    const pct=pFrom+(done*step);
    document.getElementById('ls-bar').style.width=Math.min(pct,pTo)+'%';
    await new Promise(r=>setTimeout(r,80));
  }
}

