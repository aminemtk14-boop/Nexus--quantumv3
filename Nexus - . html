// ─── RENDER FEED ──────────────────────────────────────
function renderFeed(arr){
  let d=[...arr].filter(c=>c.P>-50);
  if(sortKey==='omega')d.sort((a,b)=>b.om-a.om);
  else if(sortKey==='score')d.sort((a,b)=>b.score-a.score);
  else if(sortKey==='tbr')d.sort((a,b)=>(b._kl?.tbr||0)-(a._kl?.tbr||0));
  else if(sortKey==='vol')d.sort((a,b)=>b.q-a.q);
  const top=d.slice(0,40);
  const el=document.getElementById('feed');
  if(!top.length)return;
