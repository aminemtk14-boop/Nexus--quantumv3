/* ════════════════════════════════════════════════════
   NEXUS GENESIS — EXTRA STYLES
   ════════════════════════════════════════════════════ */

/* ── GENESIS TAB ── */
.genesis-hero {
  background: linear-gradient(135deg,
    rgba(180,75,255,.12), rgba(255,26,110,.1),
    rgba(0,255,229,.08));
  border: 1px solid rgba(180,75,255,.35);
  border-radius: 14px; padding: 16px; margin-bottom: 12px;
  text-align: center; position: relative; overflow: hidden;
}
.genesis-hero::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse 80% 40% at 50% 0%,
    rgba(180,75,255,.1), transparent 70%);
  pointer-events: none;
}
.genesis-logo {
  font-family: 'Orbitron', monospace; font-size: 20px;
  font-weight: 900; letter-spacing: 4px;
  background: linear-gradient(90deg,var(--c4),var(--c1),var(--c0));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  margin-bottom: 4px;
}
.genesis-sub { font-size: 9px; color: var(--txt2);
  font-family: 'IBM Plex Mono', monospace; letter-spacing: 1px; }

/* ── GENESIS SIGNAL CARD ── */
.gcard {
  background: var(--bg2);
  border-radius: 13px; padding: 13px; margin-bottom: 9px;
  cursor: pointer; animation: ci .22s ease both;
  position: relative; overflow: hidden;
  transition: border-color .15s, box-shadow .15s;
}
.gcard::before {
  content: ''; position: absolute;
  top: 0; left: 0; bottom: 0; width: 3px;
  border-radius: 13px 0 0 13px;
}
.gcard.genesis { border: 1px solid rgba(180,75,255,.45);
  box-shadow: 0 0 22px rgba(180,75,255,.12); }
.gcard.genesis::before {
  background: linear-gradient(180deg,var(--c4),var(--c1),var(--c0));
  background-size: 100% 300%; animation: omB 1.2s linear infinite;
}
.gcard.critical { border: 1px solid rgba(255,26,110,.5);
  box-shadow: 0 0 28px rgba(255,26,110,.15); }
.gcard.critical::before {
  background: linear-gradient(180deg,var(--c1),#ff00cc);
  background-size: 100% 200%; animation: omB .8s linear infinite;
}
.gcard.strong2 { border: 1px solid rgba(255,214,10,.28); }
.gcard.strong2::before { background: var(--c2); }
.gcard.watch2 { border: 1px solid rgba(0,255,229,.15); }
.gcard.watch2::before { background: var(--c0); }
.gcard:active { transform: scale(.984); }

/* ── GENESIS SCORE RING ── */
.genesis-ring-wrap {
  display: flex; align-items: center; gap: 14px;
  padding: 12px; background: rgba(255,255,255,.02);
  border-radius: 10px; margin-bottom: 10px;
}
.genesis-ring { position: relative; width: 88px; height: 88px; flex-shrink: 0; }
.genesis-ring svg { transform: rotate(-90deg); }
.gr-bg { fill: none; stroke: rgba(255,255,255,.05); stroke-width: 8; }
.gr-fill {
  fill: none; stroke-width: 8; stroke-linecap: round;
  transition: stroke-dasharray 1.4s cubic-bezier(.22,1,.36,1);
}
.gr-num {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  flex-direction: column;
}
.gr-val {
  font-family: 'Orbitron', monospace;
  font-size: 18px; font-weight: 900;
}
.gr-lbl { font-size: 7px; color: var(--txt2); margin-top: 1px;
  font-family: 'IBM Plex Mono', monospace; letter-spacing: .5px; }
.genesis-info h3 { font-size: 13px; font-weight: 800; margin-bottom: 3px; }
.genesis-info p { font-size: 10px; color: var(--txt2); line-height: 1.45; }

/* ── GENESIS FACTOR TABLE ── */
.gfactors {
  background: rgba(255,255,255,.02);
  border-radius: 10px; padding: 10px; margin-bottom: 10px;
}
.gft { font-size: 8px; color: var(--txt2);
  margin-bottom: 7px; letter-spacing: .4px;
  font-family: 'IBM Plex Mono', monospace; }
.gfrow {
  display: flex; align-items: center; gap: 5px;
  margin-bottom: 4px; padding-bottom: 4px;
  border-bottom: 1px solid rgba(255,255,255,.03);
}
.gfrow:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
.gf-ic { font-size: 12px; flex-shrink: 0; width: 16px; text-align: center; }
.gf-nm { font-size: 9px; color: var(--txt); flex: 1; min-width: 0;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.gf-bg { width: 65px; height: 4px;
  background: rgba(255,255,255,.05); border-radius: 2px;
  overflow: hidden; flex-shrink: 0; }
.gf-fill { height: 100%; border-radius: 2px; transition: width .8s ease; }
.gf-v { font-size: 9px; font-weight: 700;
  font-family: 'IBM Plex Mono', monospace;
  min-width: 30px; text-align: left; flex-shrink: 0; }
.gf-st { font-size: 10px; flex-shrink: 0; }

/* ── GENESIS PLAN ── */
.gplan {
  background: rgba(0,255,229,.025);
  border: 1px solid rgba(0,255,229,.1);
  border-radius: 8px; padding: 8px;
  display: grid; grid-template-columns: repeat(4,1fr);
  gap: 4px; margin-bottom: 8px;
}
.gpi { text-align: center; }
.gpl { font-size: 7px; color: var(--txt2); }
.gpv { font-size: 10px; font-weight: 700;
  font-family: 'IBM Plex Mono', monospace; margin-top: 2px; }

/* ── GENESIS ACTIONS ── */
.gacts { display: flex; gap: 6px; }
.gbtn {
  flex: 1; border: none; border-radius: 7px;
  padding: 8px; font-size: 10px; font-weight: 800;
  cursor: pointer; font-family: 'Cairo', sans-serif;
  transition: all .12s;
}
.gbtn-main {
  background: linear-gradient(90deg,var(--c4),var(--c1));
  color: #fff;
}
.gbtn-w {
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.07);
  color: var(--txt2);
}

/* ── FILTER PILLS ── */
.gfilters {
  display: flex; gap: 6px; margin-bottom: 12px;
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  scrollbar-width: none; padding-bottom: 3px;
}
.gfilters::-webkit-scrollbar { display: none; }
.gfilt {
  border: 1px solid rgba(255,255,255,.08);
  border-radius: 20px; padding: 5px 12px;
  font-size: 9px; font-weight: 700; cursor: pointer;
  white-space: nowrap; flex-shrink: 0;
  background: rgba(255,255,255,.03);
  color: var(--txt2); transition: all .12s;
}
.gfilt.on {
  background: rgba(180,75,255,.15);
  border-color: var(--c4); color: var(--c4);
}

/* ── GENESIS TOP STRIP ── */
.genesis-strip {
  display: flex; gap: 7px;
  overflow-x: auto; -webkit-overflow-scrolling: touch;
  scrollbar-width: none; padding-bottom: 4px; margin-bottom: 12px;
}
.genesis-strip::-webkit-scrollbar { display: none; }
.gstrip-item {
  background: linear-gradient(135deg,
    rgba(180,75,255,.18), rgba(255,26,110,.1));
  border: 1px solid rgba(180,75,255,.45);
  border-radius: 10px; padding: 8px 11px;
  cursor: pointer; white-space: nowrap; flex-shrink: 0;
  min-width: 88px; text-align: center;
  transition: transform .12s;
}
.gstrip-item:active { transform: scale(.94); }
.gsi-sym {
  font-family: 'Orbitron', monospace;
  font-size: 12px; font-weight: 900; color: var(--c0);
}
.gsi-conf {
  font-size: 10px; font-weight: 700; margin-top: 2px;
}
.gsi-time { font-size: 8px; color: var(--txt2); margin-top: 1px; }

/* ── GENESIS EMPTY ── */
.genesis-empty {
  text-align: center; padding: 40px 20px; color: var(--txt2);
}


