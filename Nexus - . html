<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<title>⚡ NEXUS OMEGA v2</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@700;900&family=IBM+Plex+Mono:wght@400;600;700&family=Cairo:wght@400;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --c0:#00ffe5;--c1:#ff1a6e;--c2:#ffd60a;--c3:#39ff14;
  --c4:#b44bff;--c5:#ff6a00;--c6:#00aaff;
  --bg:#000205;--bg2:#040c16;--bg3:#060f1c;
  --txt:#c0e8ff;--txt2:#2e5f7a;--txt3:#0f2233;
  --border:rgba(0,255,229,.06);
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--txt);font-family:'Cairo',sans-serif;display:flex;flex-direction:column}
body::before{content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(rgba(0,255,229,.013) 1px,transparent 1px),linear-gradient(90deg,rgba(0,255,229,.013) 1px,transparent 1px);
  background-size:32px 32px;animation:bgG 35s linear infinite}
@keyframes bgG{to{background-position:32px 32px}}

/* ─── HEADER ─── */
#hdr{position:relative;z-index:300;background:rgba(0,2,5,.98);backdrop-filter:blur(20px);
  border-bottom:1px solid var(--border);padding:9px 12px;
  display:flex;align-items:center;justify-content:space-between;flex-shrink:0;gap:6px}
.hl{display:flex;align-items:center;gap:8px}
.lm{width:34px;height:34px;border-radius:8px;
  background:linear-gradient(135deg,var(--c0),var(--c1));
  display:flex;align-items:center;justify-content:center;
  font-size:15px;font-weight:900;color:#000;font-family:'Orbitron',monospace;
  box-shadow:0 0 14px rgba(0,255,229,.4);flex-shrink:0;
  animation:lp 3s ease-in-out infinite}
@keyframes lp{0%,100%{box-shadow:0 0 14px rgba(0,255,229,.4)}50%{box-shadow:0 0 26px rgba(0,255,229,.7),0 0 50px rgba(255,26,110,.2)}}
.lt{font-family:'Orbitron',monospace;font-size:13px;font-weight:900;letter-spacing:2px}
.lt span{background:linear-gradient(90deg,var(--c0),var(--c1));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.ls{font-size:8px;color:var(--txt2);font-family:'IBM Plex Mono',monospace;margin-top:1px}
.hr{display:flex;align-items:center;gap:6px;flex-wrap:wrap}

/* Status */
.stpill{display:flex;align-items:center;gap:4px;border-radius:14px;padding:4px 8px;font-size:9px;
  font-family:'IBM Plex Mono',monospace;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06)}
.sd{width:6px;height:6px;border-radius:50%;background:var(--txt2);transition:all .3s;flex-shrink:0}
.sd.live{background:var(--c3);box-shadow:0 0 6px var(--c3);animation:sdp 2s ease-in-out infinite}
.sd.loading{background:var(--c2);animation:sdp .5s ease-in-out infinite}
.sd.err{background:var(--c1)}
@keyframes sdp{0%,100%{opacity:1}50%{opacity:.3}}
.hb{background:rgba(0,255,229,.07);border:1px solid rgba(0,255,229,.15);border-radius:7px;
  padding:6px 10px;color:var(--c0);font-size:11px;cursor:pointer;font-weight:700;
  font-family:'Cairo',sans-serif;transition:all .15s;white-space:nowrap}
.hb:active{background:rgba(0,255,229,.18);transform:scale(.96)}

/* countdown ring */
#cd-wrap{position:relative;width:32px;height:32px;flex-shrink:0;cursor:pointer}
#cd-svg{transform:rotate(-90deg)}
#cd-bg{fill:none;stroke:rgba(255,255,255,.06);stroke-width:3}
#cd-fill{fill:none;stroke:var(--c0);stroke-width:3;stroke-linecap:round;transition:stroke-dashoffset .5s linear;stroke-dasharray:88;stroke-dashoffset:0}
#cd-txt{position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  font-family:'IBM Plex Mono',monospace;font-size:8px;font-weight:700;color:var(--c0)}

/* ─── INTEL TICKER ─── */
#itick{position:relative;z-index:200;background:rgba(0,2,5,.97);border-bottom:1px solid var(--border);padding:5px 0;overflow:hidden;flex-shrink:0}
.it-in{display:inline-flex;gap:18px;animation:itk 50s linear infinite;padding:0 8px}
.it-in:hover{animation-play-state:paused}
@keyframes itk{to{transform:translateX(-50%)}}
.it-i{font-family:'IBM Plex Mono',monospace;font-size:9px;color:var(--txt2);display:inline-flex;align-items:center;gap:4px;white-space:nowrap}
.its{color:var(--c0);font-weight:700}
.itu{color:var(--c3)}.itd{color:var(--c1)}
.ittbr{font-size:8px;color:var(--c2)}
.itsep{color:var(--txt3)}

/* ─── TABS ─── */
#tabs{position:relative;z-index:200;background:rgba(0,2,5,.96);border-bottom:1px solid var(--border);
  display:flex;padding:0 8px;flex-shrink:0;overflow-x:auto;scrollbar-width:none}
#tabs::-webkit-scrollbar{display:none}
.tab{padding:9px 12px;font-size:10px;cursor:pointer;color:var(--txt2);
  border-bottom:2px solid transparent;font-weight:700;white-space:nowrap;flex-shrink:0;transition:color .15s}
.tab.active{color:var(--c0);border-color:var(--c0)}
.tbadge{background:var(--c1);border-radius:8px;padding:1px 4px;font-size:7px;color:#fff;
  margin-right:2px;animation:sdp 1.2s ease-in-out infinite;display:inline-block;min-width:14px;text-align:center}

/* ─── MAIN ─── */
#main{flex:1;overflow:hidden;position:relative;z-index:1}
.view{display:none;height:100%;overflow-y:auto;-webkit-overflow-scrolling:touch;padding:10px 12px 70px}
.view.active{display:block}
.view::-webkit-scrollbar{width:2px}
.view::-webkit-scrollbar-thumb{background:rgba(0,255,229,.08)}

/* ─── LOADING STATE ─── */
#loading-screen{display:flex;position:absolute;inset:0;z-index:100;align-items:center;justify-content:center;flex-direction:column;gap:14px;background:rgba(0,2,5,.97);backdrop-filter:blur(16px)}
#loading-screen.gone{display:none}
.ls-logo{font-family:'Orbitron',monospace;font-size:22px;font-weight:900;letter-spacing:3px;background:linear-gradient(90deg,var(--c0),var(--c1));-webkit-background-clip:text;-webkit-text-fill-color:transparent;margin-bottom:4px}
.ls-sub{font-size:9px;color:var(--txt2);font-family:'IBM Plex Mono',monospace;letter-spacing:1px;margin-bottom:16px}
.ls-bar-bg{width:200px;height:3px;background:rgba(255,255,255,.06);border-radius:2px;overflow:hidden}
.ls-bar-fill{height:100%;background:linear-gradient(90deg,var(--c0),var(--c1));border-radius:2px;width:0%;transition:width .3s ease}
.ls-msg{font-size:11px;color:var(--txt2);text-align:center;max-width:260px;line-height:1.6}
.ls-step{font-size:10px;color:var(--c0);font-family:'IBM Plex Mono',monospace;margin-top:4px}
.ls-retry{background:rgba(0,255,229,.1);border:1px solid rgba(0,255,229,.3);border-radius:8px;padding:9px 20px;color:var(--c0);font-size:11px;cursor:pointer;font-family:'Cairo',sans-serif;font-weight:700;display:none;margin-top:8px}

/* ─── METRICS ─── */
.mrow{display:grid;grid-template-columns:repeat(6,1fr);gap:4px;margin-bottom:10px}
@media(max-width:380px){.mrow{grid-template-columns:repeat(3,1fr)}}
.met{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.045);border-radius:8px;padding:7px 4px;text-align:center;transition:border-color .2s,transform .15s}
.met:active{transform:scale(.95)}
.mv{font-size:14px;font-weight:900;font-family:'Orbitron',monospace}
.ml{font-size:7px;color:var(--txt2);margin-top:1px;letter-spacing:.2px}

/* ─── OMEGA ALERT ─── */
#omg-alert{margin-bottom:10px;display:none}
.oa-t{font-size:10px;font-weight:800;display:flex;align-items:center;gap:6px;margin-bottom:7px}
.oadot{width:7px;height:7px;border-radius:50%;background:var(--c1);box-shadow:0 0 8px var(--c1);animation:sdp .7s ease-in-out infinite;flex-shrink:0}
#oa-list{display:flex;gap:6px;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;padding-bottom:3px}
#oa-list::-webkit-scrollbar{display:none}
.oachip{background:linear-gradient(135deg,rgba(255,26,110,.15),rgba(255,0,153,.08));
  border:1px solid rgba(255,26,110,.42);border-radius:10px;padding:8px 10px;
  cursor:pointer;white-space:nowrap;flex-shrink:0;transition:transform .12s;min-width:90px}
.oachip:active{transform:scale(.94)}
.oas{font-family:'Orbitron',monospace;font-size:12px;font-weight:900;color:var(--c0)}
.oaom{font-size:9px;font-weight:700;margin-top:2px;color:var(--c1)}
.oatbr{font-size:9px;color:var(--c2);margin-top:1px}
.oafr{font-size:8px;color:var(--c3);margin-top:1px}

/* ─── FEED ─── */
.fhdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.ft{font-size:11px;font-weight:800;display:flex;align-items:center;gap:6px}
.lb{background:rgba(255,26,110,.1);border:1px solid rgba(255,26,110,.28);border-radius:3px;padding:1px 5px;font-size:8px;color:var(--c1);font-weight:700;letter-spacing:1px}
.srow{display:flex;gap:3px}
.sbn{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);border-radius:4px;padding:3px 7px;font-size:9px;color:var(--txt2);cursor:pointer;transition:all .12s}
.sbn.on{background:rgba(0,255,229,.08);color:var(--c0);border-color:rgba(0,255,229,.22)}

/* ─── SIGNAL CARD ─── */
.sc{background:var(--bg2);border:1px solid rgba(255,255,255,.05);border-radius:12px;
  padding:12px;margin-bottom:8px;position:relative;overflow:hidden;cursor:pointer;
  animation:ci .22s ease both;transition:border-color .15s,box-shadow .15s}
@keyframes ci{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.sc::before{content:'';position:absolute;top:0;left:0;bottom:0;width:3px;border-radius:12px 0 0 12px}
.sc.S::before{background:linear-gradient(180deg,var(--c0),var(--c3))}.sc.S{border-color:rgba(0,255,229,.15);box-shadow:0 0 16px rgba(0,255,229,.06)}
.sc.A::before{background:linear-gradient(180deg,var(--c2),var(--c5))}
.sc.B::before{background:linear-gradient(180deg,var(--c4),var(--c1))}
.sc.C::before{background:var(--txt3)}
.sc.OM::before{background:linear-gradient(180deg,var(--c1),#ff00cc,var(--c0));background-size:100% 300%;animation:omB 1.5s linear infinite}
.sc.OM{border-color:rgba(255,26,110,.42);box-shadow:0 0 20px rgba(255,26,110,.1)}
@keyframes omB{0%{background-position:0 0}100%{background-position:0 300%}}
.sc:active{transform:scale(.985)}

.sct{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:8px}
.scsym{font-family:'Orbitron',monospace;font-size:15px;font-weight:900;color:var(--c0)}
.scpair{font-size:8px;color:var(--txt2);margin-top:1px}
.scrk{width:27px;height:27px;border-radius:6px;display:flex;align-items:center;justify-content:center;font-family:'Orbitron',monospace;font-size:11px;font-weight:900}
.sc.S .scrk{background:rgba(0,255,229,.12);color:var(--c0)}
.sc.A .scrk{background:rgba(255,214,10,.1);color:var(--c2)}
.sc.B .scrk{background:rgba(180,75,255,.1);color:var(--c4)}
.sc.C .scrk,.sc.OM .scrk{background:rgba(255,26,110,.1);color:var(--c1)}

.scmid{display:grid;grid-template-columns:repeat(5,1fr);gap:4px;margin-bottom:8px}
@media(max-width:360px){.scmid{grid-template-columns:repeat(3,1fr)}}
.ss{background:rgba(255,255,255,.025);border-radius:6px;padding:5px 4px;text-align:center}
.ssv{font-size:10px;font-weight:700;font-family:'IBM Plex Mono',monospace}
.ssl{font-size:7px;color:var(--txt2);margin-top:1px}

/* Bars */
.bars{margin-bottom:8px}
.br{display:flex;align-items:center;gap:6px;margin-bottom:3px}
.brl{font-size:7px;color:var(--txt2);min-width:28px}
.brb{flex:1;height:4px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden}
.brf{height:100%;border-radius:2px;transition:width .7s ease}
.brn{font-size:9px;font-weight:800;font-family:'Orbitron',monospace;min-width:24px;text-align:left}

/* Pills */
.scpills{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:8px}
.pl{border-radius:16px;padding:2px 7px;font-size:9px;font-weight:700;display:inline-flex;align-items:center;gap:2px}

/* OMEGA indicator */
.omgind{background:rgba(255,26,110,.09);border:1px solid rgba(255,26,110,.35);
  border-radius:7px;padding:6px 9px;margin-bottom:8px;display:flex;align-items:center;gap:7px}
.omgi{font-size:12px;flex-shrink:0}
.omgt{font-size:9px;font-weight:700;color:var(--c1);flex:1;line-height:1.35}
.omgc{font-family:'IBM Plex Mono',monospace;font-size:9px;font-weight:700;color:var(--c2);white-space:nowrap}

/* TBR bar */
.tbr-b{background:rgba(255,255,255,.02);border-radius:6px;padding:5px 7px;margin-bottom:8px}
.tbr-t{font-size:8px;color:var(--txt2);margin-bottom:3px}
.tbr-tr{height:8px;background:rgba(255,26,110,.1);border-radius:4px;overflow:hidden;position:relative}
.tbr-f{height:100%;background:linear-gradient(90deg,var(--c3),var(--c0));border-radius:4px;transition:width .5s ease}
.tbr-m{position:absolute;top:0;left:50%;width:1px;height:100%;background:rgba(255,255,255,.18)}
.tbr-l{display:flex;justify-content:space-between;font-size:7px;color:var(--txt2);margin-top:3px}

/* Trade plan */
.tpl{background:rgba(0,255,229,.03);border:1px solid rgba(0,255,229,.09);border-radius:7px;
  padding:7px;display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-bottom:8px}
.ti{text-align:center}
.tl{font-size:7px;color:var(--txt2)}
.tv{font-size:10px;font-weight:700;font-family:'IBM Plex Mono',monospace;margin-top:2px}

.scacts{display:flex;gap:6px}
.sca{flex:1;border:none;border-radius:7px;padding:8px;font-size:10px;font-weight:800;cursor:pointer;font-family:'Cairo',sans-serif;transition:all .12s}
.scai{background:linear-gradient(90deg,var(--c0),var(--c6));color:#000}
.scw{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);color:var(--txt2)}

/* ─── OMEGA VIEW ─── */
.om-exp{background:rgba(255,26,110,.05);border:1px solid rgba(255,26,110,.14);border-radius:10px;padding:11px;margin-bottom:10px;font-size:10px;color:var(--txt2);line-height:1.75}
.om-exp h4{color:var(--c1);font-size:11px;margin-bottom:7px}
.conf-m{background:rgba(255,255,255,.02);border-radius:9px;padding:9px;margin-bottom:7px}
.cmt{font-size:8px;color:var(--txt2);margin-bottom:5px;letter-spacing:.3px}
.cmrow{display:flex;align-items:center;gap:6px;margin-bottom:4px}
.cml{font-size:9px;min-width:110px;color:var(--txt)}
.cmbb{flex:1;height:4px;background:rgba(255,255,255,.04);border-radius:2px;overflow:hidden}
.cmbf{height:100%;border-radius:2px}
.cmv{font-size:9px;font-family:'IBM Plex Mono',monospace;min-width:38px;text-align:left;font-weight:600}

/* ─── FUTURES ─── */
.fut-c{background:var(--bg2);border:1px solid rgba(255,255,255,.05);border-radius:10px;padding:10px;margin-bottom:7px;animation:ci .2s ease both}
.fc-h{display:flex;align-items:center;justify-content:space-between;margin-bottom:7px}
.fc-sym{font-family:'Orbitron',monospace;font-size:12px;font-weight:900;color:var(--c0)}
.fc-fr{font-size:10px;font-weight:700;font-family:'IBM Plex Mono',monospace}
.fc-g{display:grid;grid-template-columns:repeat(4,1fr);gap:5px}
.fci{background:rgba(255,255,255,.02);border-radius:5px;padding:6px;text-align:center}
.fcv{font-size:10px;font-weight:700;font-family:'IBM Plex Mono',monospace}
.fcl{font-size:7px;color:var(--txt2);margin-top:1px}
.fr-m{height:4px;background:rgba(255,255,255,.04);border-radius:2px;overflow:hidden;margin-top:6px}
.fr-f{height:100%;border-radius:2px;transition:width .4s}
.fr-l{display:flex;justify-content:space-between;font-size:7px;color:var(--txt2);margin-top:2px}

/* ─── KLINE VIEW ─── */
.kl-row{background:rgba(255,255,255,.02);border-radius:7px;padding:7px 9px;margin-bottom:5px;display:flex;align-items:center;gap:8px;cursor:pointer;transition:background .12s}
.kl-row:active{background:rgba(0,255,229,.05)}
.kl-sym{font-family:'Orbitron',monospace;font-size:11px;font-weight:700;color:var(--c0);min-width:68px}
.kl-bars{flex:1}
.kl-tr{height:6px;background:rgba(255,26,110,.1);border-radius:3px;overflow:hidden;margin-bottom:3px}
.kl-tf{height:100%;background:linear-gradient(90deg,var(--c3),var(--c0));border-radius:3px}
.kl-lbl{display:flex;justify-content:space-between;font-size:7px;color:var(--txt2)}
.kl-score{font-family:'Orbitron',monospace;font-size:10px;font-weight:700;min-width:26px;text-align:center}

/* ─── WATCHLIST ─── */
.wl-empty{text-align:center;padding:40px;color:var(--txt2)}
.wli{background:var(--bg2);border:1px solid rgba(255,255,255,.045);border-radius:9px;padding:10px 11px;display:flex;align-items:center;gap:8px;margin-bottom:6px;cursor:pointer;transition:border-color .12s}
.wli:hover{border-color:rgba(0,255,229,.15)}
.wlsym{font-family:'Orbitron',monospace;font-size:12px;font-weight:700;color:var(--c0);flex:0 0 62px}
.wlp{font-family:'IBM Plex Mono',monospace;font-size:10px;flex:1}
.wla{font-size:8px;margin-top:1px}
.wlch{font-size:10px;font-weight:700;font-family:'IBM Plex Mono',monospace;min-width:50px;text-align:center}
.wldel{background:rgba(255,26,110,.07);border:1px solid rgba(255,26,110,.15);border-radius:4px;padding:3px 6px;font-size:9px;color:var(--c1);cursor:pointer;flex-shrink:0}

/* ─── JOURNAL ─── */
.jform{background:var(--bg2);border:1px solid rgba(0,255,229,.08);border-radius:11px;padding:12px;margin-bottom:10px}
.jft{font-size:12px;font-weight:800;color:var(--c0);margin-bottom:9px}
.jgrid{display:grid;grid-template-columns:1fr 1fr;gap:6px}
.jfull{grid-column:1/-1}
.jl{font-size:9px;color:var(--txt2);margin-bottom:2px}
.ji{width:100%;background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:6px;padding:7px 9px;color:var(--txt);font-size:11px;outline:none;font-family:'IBM Plex Mono',monospace;transition:border-color .2s}
.ji:focus{border-color:var(--c0)}
.js{width:100%;background:var(--bg2);border:1px solid rgba(255,255,255,.08);border-radius:6px;padding:7px 9px;color:var(--txt);font-size:11px;outline:none}
.jbtn{background:linear-gradient(90deg,var(--c0),var(--c6));border:none;border-radius:8px;padding:9px;color:#000;font-weight:900;font-size:11px;cursor:pointer;width:100%;margin-top:8px;font-family:'Cairo',sans-serif}
.jsbar{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px}
.je{background:var(--bg2);border:1px solid rgba(255,255,255,.04);border-radius:8px;padding:10px;margin-bottom:6px}
.je-hd{display:flex;justify-content:space-between;align-items:center;margin-bottom:7px}
.je-sym{font-family:'Orbitron',monospace;font-size:11px;font-weight:700}
.je-res{border-radius:4px;padding:2px 6px;font-size:10px;font-weight:700}
.win{background:rgba(57,255,20,.09);color:var(--c3)}.loss{background:rgba(255,26,110,.09);color:var(--c1)}.be{background:rgba(255,214,10,.07);color:var(--c2)}
.je-sts{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;font-size:9px;text-align:center}
.je-sv{font-family:'IBM Plex Mono',monospace;font-weight:700}
.je-sl{color:var(--txt2);margin-top:1px}
.je-nt{font-size:10px;color:var(--txt2);margin-top:6px;padding-top:6px;border-top:1px solid rgba(255,255,255,.04);line-height:1.5}
.je-del{background:rgba(255,26,110,.07);border:none;border-radius:4px;padding:2px 5px;color:var(--c1);font-size:9px;cursor:pointer}

/* ─── MODAL ─── */
#mover{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:500;align-items:flex-end}
#mover.open{display:flex}
#mod{background:linear-gradient(180deg,var(--bg2),var(--bg));border:1px solid rgba(0,255,229,.15);
