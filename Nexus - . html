// ─── CORS FETCH ────────────────────────────────────────
async function cfetch(url){
  // Try each proxy in order — auto-selects working one
  var startIdx = PROXY_IDX;
  for(var attempt=0; attempt<PROXY_FUNCS.length; attempt++){
    var idx = (startIdx + attempt) % PROXY_FUNCS.length;
    try{
      var proxyUrl = PROXY_FUNCS[idx](url);
      var ctrl = new AbortController();
      var tmo = setTimeout(function(){ctrl.abort();}, 9000);
      var headers = {};
      // cors.sh requires origin header
      if(proxyUrl.indexOf('proxy.cors.sh')>=0) headers['x-cors-api-key']='temp_free';
      var r = await fetch(proxyUrl, {signal:ctrl.signal, headers:headers});
      clearTimeout(tmo);
      if(r.ok){
        var txt = await r.text();
        try{
          var data = JSON.parse(txt);
          PROXY_IDX = idx; // remember working proxy
          setStatus('live');
          return data;
        }catch(e2){
          // Text response — try to parse anyway
          if(txt && txt.trim().startsWith('[')||txt.trim().startsWith('{')){
            var data2 = JSON.parse(txt);
            PROXY_IDX = idx;
            return data2;
          }
        }
      }
    }catch(err){}
    // Small delay between attempts
    await new Promise(function(r2){setTimeout(r2, 300);});
  }
  throw new Error('جميع الـ CORS Proxies فشلت — تحقق من الإنترنت');
}

// ─── SCORE ENGINE ──────────────────────────────────────
function computeScore(c){
  let s=0;
  const ch=c.P, vol=c.q, last=c.c, open=c.o, hi=c.h, lo=c.l;
  const kl=c._kl, f=c._fut;
  if(ch>25)s+=30;else if(ch>15)s+=26;else if(ch>8)s+=20;else if(ch>4)s+=14;else if(ch>1)s+=8;else if(ch>0)s+=3;
  if(vol>100e6)s+=22;else if(vol>50e6)s+=19;else if(vol>20e6)s+=15;else if(vol>5e6)s+=10;else if(vol>1e6)s+=6;else if(vol>200e3)s+=2;
  if(hi>lo){const p=(last-lo)/(hi-lo);s+=Math.round(p*12)}
  if(open>0){const bo=((last-open)/open)*100;if(bo>15)s+=8;else if(bo>8)s+=6;else if(bo>3)s+=4;else if(bo>0.5)s+=2}
  if(f){if(f.frS==='BX')s+=8;else if(f.frS==='B')s+=5;else if(f.frS==='BX_')s-=5;}
  if(kl&&kl.tbr>0.6)s+=8;else if(kl&&kl.tbr>0.52)s+=4;
  if(ch>5&&vol>5e6)s+=5;else if(ch>2&&vol>1e6)s+=3;
  const hv=HVOL.get(c.s)||[];
  if(hv.length>=5){const m=hv.reduce((a,b)=>a+b,0)/hv.length;const d=Math.sqrt(hv.reduce((a,v)=>a+(v-m)**2,0)/hv.length)||1;const z=(vol-m)/d;c.z=+z.toFixed(2);if(z>=3)s+=10;else if(z>=2)s+=7;else if(z>=1.5)s+=4;}else c.z=0;
  return Math.min(Math.max(s,0),100);
}

function omegaScore(c){
  let s=0;
  const ch=c.P, vol=c.q, last=c.c, open=c.o, hi=c.h, lo=c.l;
  const kl=c._kl, f=c._fut, hv=HVOL.get(c.s)||[];

  // F1: Taker Buy Ratio (25pts)
  if(kl){
    const tbr=kl.tbr;
    if(tbr>0.72)s+=25;else if(tbr>0.65)s+=20;else if(tbr>0.58)s+=14;else if(tbr>0.52)s+=8;else if(tbr>0.48)s+=4;
    if(kl.trend>0.05)s+=5;else if(kl.trend>0.02)s+=3;
    if(kl.vwap>0&&last>kl.vwap){const d=(last-kl.vwap)/kl.vwap*100;if(d>1)s+=5;else if(d>0.3)s+=3;}
    if(kl.vel>3)s+=5;else if(kl.vel>1)s+=3;else if(kl.vel>0)s+=1;
  }else{if(vol>20e6&&ch>3)s+=18;else if(vol>5e6&&ch>1)s+=10;}

  // F2: Z-Score (20pts)
  if(hv.length>=5){const m=hv.reduce((a,b)=>a+b,0)/hv.length;const d=Math.sqrt(hv.reduce((a,v)=>a+(v-m)**2,0)/hv.length)||1;const z=(vol-m)/d;c.z=+z.toFixed(2);if(z>=4)s+=20;else if(z>=3)s+=16;else if(z>=2)s+=11;else if(z>=1.5)s+=7;else if(z>=1)s+=3;}

  // F3: Whale accumulation (15pts)
  const isW=Math.abs(ch)<5&&vol>2e6;const isS=ch>0.5&&ch<8&&vol>3e6;
  if(isW)s+=15;else if(isS)s+=11;else if(ch>0&&vol>1e6)s+=5;

  // F4: Funding Rate (15pts)
  if(f){
    if(f.frS==='BX')s+=15;else if(f.frS==='B')s+=10;else if(f.frS==='BX_')s-=8;
    if(f.prem>0.08)s+=7;else if(f.prem>0.03)s+=4;
  }

  // F5: Range position (10pts)
  if(hi>lo){const p=(last-lo)/(hi-lo);if(p>0.8&&Math.abs(ch)<8)s+=10;else if(p>0.65&&Math.abs(ch)<15)s+=6;else if(p>0.5)s+=3;}

  // F6: Stealth open breakout (5pts)
  if(open>0){const bo=((last-open)/open)*100;if(bo>0.5&&bo<6)s+=5;else if(bo>6&&bo<15)s+=3;else if(bo>0)s+=1;}

  // F7: Trade density (5pts)
  if(c.n>100000)s+=5;else if(c.n>50000)s+=3;else if(c.n>10000)s+=1;

  // F8: Price velocity from history (5pts)
  const hp=HPRC.get(c.s)||[];
  if(hp.length>=3){const v=(last-hp[0])/hp[0]*100;if(v>2&&v<20)s+=5;}

  return Math.min(Math.max(s,0),100);
}

function getRank(s){
  if(s>=80)return{r:'S',col:'var(--c0)',bg:'rgba(0,255,229,.1)',lbl:'🚀 انفجاري',desc:'زخم استثنائي'};
  if(s>=60)return{r:'A',col:'var(--c2)',bg:'rgba(255,214,10,.08)',lbl:'🔥 قوي',desc:'حركة مدعومة بالبيانات'};
  if(s>=35)return{r:'B',col:'var(--c4)',bg:'rgba(180,75,255,.08)',lbl:'⚡ صاعد',desc:'إشارات إيجابية'};
  return{r:'C',col:'var(--txt2)',bg:'rgba(255,255,255,.025)',lbl:'😐 محايد',desc:'ضعيف'};
}

function getSigs(c){
  const s=[],kl=c._kl,f=c._fut,om=c.om||0,z=c.z||0;
  if(om>=70)s.push({i:'⚡',l:'OMEGA',c:'var(--c1)',b:'rgba(255,26,110,.1)'});
  if(kl&&kl.tbr>0.65)s.push({i:'🟢',l:`TBR ${(kl.tbr*100).toFixed(0)}%`,c:'var(--c3)',b:'rgba(57,255,20,.07)'});
  if(z>=3)s.push({i:'📊',l:`Z=${z}σ`,c:'var(--c2)',b:'rgba(255,214,10,.07)'});
  if(c.P>10)s.push({i:'🚀',l:'زخم',c:'var(--c0)',b:'rgba(0,255,229,.07)'});
  if(c.q>50e6)s.push({i:'💥',l:'حجم ضخم',c:'var(--c5)',b:'rgba(255,106,0,.09)'});
  if(f?.frS==='BX')s.push({i:'💰',l:'FR متطرف',c:'var(--c3)',b:'rgba(57,255,20,.06)'});
  if(kl&&kl.trend>0.05)s.push({i:'📈',l:'Taker↑',c:'var(--c4)',b:'rgba(180,75,255,.08)'});
  if(c.P>30)s.push({i:'⚠️',l:'pump؟',c:'var(--c1)',b:'rgba(255,26,110,.08)'});
  return s.slice(0,5);
}

function calcPlan(c){
  const last=c.c,hi=c.h,lo=c.l,f=c._fut,kl=c._kl;
  const sup=Math.max(lo,last*0.975);const sl=sup*0.984;const d=last-sl;
  const t1=last+d*2,t2=last+d*3,t3=last+d*4.5;const rr=(t1-last)/(last-sl);
  const tbrB=kl&&kl.tbr>0.65?10:kl&&kl.tbr>0.55?5:0;
  const frB=f?.frS==='BX'?10:f?.frS==='B'?5:0;
  const prob=Math.min(Math.max(28+(c.score||0)*0.28+(c.om||0)*0.08+tbrB+frB,30),80);
  return{entry:last,sl,t1,t2,t3,rr,prob:prob.toFixed(0)};
}

// ─── FORMATTERS ────────────────────────────────────────
const fmt=(n,d=2)=>Number(n).toFixed(d);
function fmtB(n){n=+n;if(n>=1e9)return(n/1e9).toFixed(2)+'B';if(n>=1e6)return(n/1e6).toFixed(2)+'M';if(n>=1e3)return(n/1e3).toFixed(2)+'K';return n.toFixed(2)}
function fmtP(p){p=+p;if(!p||isNaN(p))return'—';if(p<0.00001)return p.toPrecision(2);if(p<0.001)return p.toPrecision(3);if(p<0.1)return p.toPrecision(4);if(p<1)return p.toPrecision(5);if(p<100)return fmt(p,3);return fmt(p,2)}
function fmtFR(r){r=+r*100;return(r>=0?'+':'')+r.toFixed(4)+'%'}
function frCol(s){return s==='BX'||s==='B'?'var(--c3)':s==='BX_'||s==='BR'?'var(--c1)':'var(--txt2)'}
function tbrC(t){return t>0.65?'var(--c3)':t>0.55?'var(--c2)':t<0.45?'var(--c1)':'var(--txt2)'}

